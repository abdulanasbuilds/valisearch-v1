# =============================================================================
# ValiSearch — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and NEVER committed to version control.
#
# All variables use the VITE_ prefix so Vite bundles them into the client.
# Keys are resolved at runtime in order:
#   1. User-provided keys stored in browser localStorage (via API Settings)
#   2. VITE_ environment variables set here
#   3. Graceful fallback to mock/demo data
# =============================================================================

# ─── AI Providers (priority order: OpenRouter → Groq → Gemini) ───────────────

# OpenRouter — 100+ models, free tier available (https://openrouter.ai)
VITE_OPENROUTER_API_KEY= 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
VITE_OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Groq — Fast Llama inference, free tier (https://console.groq.com)
VITE_GROQ_API_KEY= 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
VITE_GROQ_MODEL=llama-3.1-8b-instant

# Gemini — Google AI, free tier (https://aistudio.google.com)
VITE_GEMINI_API_KEY= AIzaSyCbg5zbHBqNv8M45p9bMrZ6B9FVj1tL5Jk
VITE_GEMINI_MODEL=gemini-1.5-flash

# ─── App Config ───────────────────────────────────────────────────────────────

