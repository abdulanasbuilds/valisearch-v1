# ═══════════════════════════════════════════════════════════
# ValiSearch — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and safe for local development.
#
# PUBLIC variables (VITE_ prefix) — bundled by Vite, safe for browser.
# SECRET variables — only in Supabase Edge Functions, NEVER prefix with VITE_.
# ═══════════════════════════════════════════════════════════

# ─── Supabase (REQUIRED for full functionality) ─────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
#
# NEW (2025 - RECOMMENDED): Use Publishable Key
# Format: sb_publishable_k_...
# Benefits: Instant revocation, zero-downtime rotation, audit logging
VITE_SUPABASE_PUBLISHABLE_KEY=

# LEGACY (still works): Anon Key (JWT format)
# Format: eyJhbGciOiJIUzI1NiIs...
# Will be deprecated after Nov 2025
VITE_SUPABASE_ANON_KEY=

# Project URL (same for both key types)
VITE_SUPABASE_URL=

# ─── Stripe (Optional — for payments) ─────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── App Configuration ─────────────────────────────────────
VITE_APP_URL=http://localhost:5000
VITE_APP_NAME=ValiSearch

# ─── Secret (Edge Functions only — add in Supabase dashboard) ─
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# SERPAPI_KEY=
# BRAVE_SEARCH_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
