# =============================================================================
# ValiSearch — Environment Variables (Next.js)
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and NEVER committed to version control.
#
# Client-side keys use the NEXT_PUBLIC_ prefix.
# Server-side keys do NOT use the NEXT_PUBLIC_ prefix.
# =============================================================================

# ─── AI Providers (server-only - keep secret) ────────────────────────────────

# OpenRouter — 100+ models, free tier (https://openrouter.ai)
OPENROUTER_API_KEY=
NEXT_PUBLIC_OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Groq — Fast Llama inference, free tier (https://console.groq.com)
GROQ_API_KEY=
NEXT_PUBLIC_GROQ_MODEL=llama-3.1-8b-instant

# Gemini — Google AI, free tier (https://aistudio.google.com)
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_MODEL=gemini-1.5-flash

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=

# Claude / Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── Search & Data APIs (server-only) ────────────────────────────────────────

# Brave Search (https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=

# SerpAPI — Google search (https://serpapi.com)
SERPAPI_KEY=

# ─── Business Intelligence (server-only) ─────────────────────────────────────

# Clearbit (https://clearbit.com)
CLEARBIT_API_KEY=

# Crunchbase (https://data.crunchbase.com)
CRUNCHBASE_API_KEY=

# ─── Branding & Domain APIs (server-only) ────────────────────────────────────

# Logo.dev (https://logo.dev)
LOGO_DEV_API_KEY=

# Namecheap (https://www.namecheap.com/support/api/intro/)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=

# GoDaddy (https://developer.godaddy.com)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ─── Database (Supabase) ────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments (Stripe) ──────────────────────────────────────────────────────

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Analytics (server-only) ─────────────────────────────────────────────────

POSTHOG_API_KEY=
